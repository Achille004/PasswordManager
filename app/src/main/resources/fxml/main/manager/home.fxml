<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane minHeight="513.0" minWidth="642.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <VBox alignment="CENTER" minHeight="503.0" minWidth="632.0">
      <children>
          <ImageView fitHeight="445.0" fitWidth="445.0" pickOnBounds="true" preserveRatio="true" VBox.vgrow="ALWAYS">
              <Image url="@../../../images/background.png" />
          </ImageView>
          <Label fx:id="homeDescTop" alignment="CENTER" contentDisplay="CENTER" minHeight="29.0" styleClass="bold-italic, regular-medium, green-text" text="Your Accounts." />
          <Label fx:id="homeDescBtm" alignment="CENTER" contentDisplay="CENTER" minHeight="29.0" styleClass="bold-italic, regular-medium, green-text" text="In a Safe Place." />
      </children>
   </VBox>
   <stylesheets>
      <URL value="@../../css/root.css" />
      <URL value="@../../css/style.css" />
   </stylesheets>
   <padding>
      <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
   </padding>
</StackPane>
