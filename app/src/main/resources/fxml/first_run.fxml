<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import password.manager.lib.ReadablePasswordFieldWithStr?>

<AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="600.0" minWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <GridPane alignment="CENTER" prefHeight="550.0" prefWidth="900.0" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
     <columnConstraints>
       <ColumnConstraints hgrow="NEVER" minWidth="10.0" prefWidth="450.0" />
       <ColumnConstraints hgrow="NEVER" minWidth="10.0" prefWidth="200.0" />
     </columnConstraints>
     <rowConstraints>
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
     </rowConstraints>
      <children>
         <Label fx:id="firstRunTitle" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="600.0" styleClass="title, green-text" text="Hi!" GridPane.columnSpan="2" GridPane.halignment="CENTER" GridPane.valignment="CENTER" />
         <AnchorPane minHeight="75.0" minWidth="650.0" GridPane.columnSpan="2" GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="CENTER">
            <children>
               <Label fx:id="firstRunDescTop" alignment="BOTTOM_CENTER" layoutY="16.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="50.0" minWidth="650.0" prefWidth="650.0" styleClass="italic, light-grey-text" text="Before getting started with PasswordManager, I need you to insert a strong password in order to protect your accounts&#10;" textAlignment="CENTER" wrapText="true" AnchorPane.topAnchor="25.0" />
               <Label fx:id="firstRunDescBtm" alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="25.0" minWidth="650.0" styleClass="italic, light-grey-text" text="PasswordManager will NEVER collect your data *" textAlignment="CENTER" wrapText="true" />
            </children>
         </AnchorPane>
         <ReadablePasswordFieldWithStr fx:id="firstRunPassword" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="30.0" minWidth="650.0" GridPane.columnSpan="2" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="CENTER" />
         <Label fx:id="firstRunTermsCred" alignment="TOP_LEFT" minHeight="45.0" minWidth="450.0" onMouseClicked="#showEula" text="Terms and Credits" GridPane.halignment="LEFT" GridPane.rowIndex="3" GridPane.valignment="TOP">
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor>
            <graphic>
               <CheckBox fx:id="firstRunCheckBox" mnemonicParsing="false" text="I've read the" />
            </graphic>
            <padding>
               <Insets top="10.0" />
            </padding>
            <styleClass>
               <String fx:value="firstrun-link" />
               <String fx:value="green-text" />
            </styleClass>
         </Label>
         <Button fx:id="firstRunSubmitBtn" alignment="CENTER" contentDisplay="CENTER" minHeight="40.0" minWidth="100.0" mnemonicParsing="false" nodeOrientation="RIGHT_TO_LEFT" onAction="#doFirstRun" styleClass="green-button, bold" text="Let's go!" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.halignment="RIGHT" GridPane.rowIndex="3" GridPane.valignment="TOP" />
      </children>
      <padding>
         <Insets bottom="125.0" left="125.0" right="125.0" top="125.0" />
      </padding>
   </GridPane>
   <Label fx:id="firstRunDisclaimer" alignment="CENTER" layoutY="550.0" minHeight="50.0" minWidth="900.0" styleClass="light-grey-text, regular-small" text="* If you intend to link Google Drive to your data, make sure you read their privacy policy" textAlignment="CENTER" wrapText="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
      <padding>
         <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
      </padding></Label>
   <stylesheets>
      <URL value="@css/root.css" />
      <URL value="@css/style.css" />
   </stylesheets>
</AnchorPane>
