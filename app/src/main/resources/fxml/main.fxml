                </graphic>
                <padding>
                  <Insets bottom="1.0" left="1.0" right="1.0" top="1.0" />
                </padding>
                <cursor>
                  <Cursor fx:constant="HAND" />
                </cursor>
            </Button>
            <Button contentDisplay="GRAPHIC_ONLY" graphicTextGap="0.0" layoutX="865.0" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#folderNavBarAction" prefHeight="35.0" prefWidth="35.0" text="F" HBox.hgrow="NEVER">
