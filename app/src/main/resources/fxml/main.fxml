<BorderPane fx:id="mainPane" minHeight="600.0" minWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <HBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" prefHeight="35.0" styleClass="title-bar" BorderPane.alignment="CENTER">
            <Label fx:id="psmgTitle" layoutX="6.0" maxWidth="1.7976931348623157E308" minHeight="35.0" styleClass="bold-italic, regular-medium" text="Password Manager" HBox.hgrow="ALWAYS">
            <padding>
               <Insets left="8.0" />
            </padding></Label>
            <Button contentDisplay="GRAPHIC_ONLY" graphicTextGap="0.0" layoutX="795.0" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#settingsNavBarAction" prefHeight="35.0" prefWidth="35.0" text="S" HBox.hgrow="NEVER">
                <graphic>
                    <ImageView fx:id="settingsButtonImageView" fitHeight="33.0" fitWidth="33.0" pickOnBounds="true" preserveRatio="true">
                        <Image url="@../images/icons/navbar/settings.png" />
                    </ImageView>
                </graphic>
                <padding>
                   <Insets bottom="1.0" left="1.0" right="1.0" top="1.0" />
                </padding>
                <cursor>
                    <Cursor fx:constant="HAND" />
                </cursor>
            </Button>
            <Button contentDisplay="GRAPHIC_ONLY" graphicTextGap="0.0" layoutX="830.0" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onMouseClicked="#showEula" prefHeight="35.0" prefWidth="35.0" text="E" HBox.hgrow="NEVER">
                <graphic>
                   <ImageView fitHeight="33.0" fitWidth="33.0" pickOnBounds="true" preserveRatio="true">
                      <Image url="@../images/icons/navbar/info.png" />
